# ── NeuroScan AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values before running.

# ── Flask / JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no setup needed):
# DATABASE_URL is auto-set to neuroscan.db in the project root

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/neuroscan

# ── Flask environment ─────────────────────────────────────────────────────────
FLASK_ENV=development      # set to 'production' when deploying
PORT=5000                  # port Flask listens on

# ── React (client/.env) ───────────────────────────────────────────────────────
# Only needed in development when running React separately from Flask.
# In production React is served by Flask from client/build — leave blank.
# REACT_APP_API_URL=http://localhost:5000/api
